# LLM
# BYOK-only: users supply their own Anthropic/OpenAI/Local key in Settings.
# No platform LLM keys. Local provider endpoint (used with the user's local key):
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.1:8b

# Encryption (for user BYOK keys at rest — 32-byte hex random, 64 hex chars)
ENCRYPTION_SECRET=

# Session (HMAC secret for wallet ownership cookies — long random string)
SESSION_SECRET=

# DeFi Data
ZERION_API_KEY=zk_...
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Supabase (Postgres key store only — no Supabase Auth; server-side service role)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Wallet Connect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
